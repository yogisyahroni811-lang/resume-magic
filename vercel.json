{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "devCommand": "vite dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "regions": ["sin1"],
  "env": {
    "NODE_VERSION": "20"
  }
}
