{
  "buildCommand": "vite build",
  "outputDirectory": "dist/client",
  "devCommand": "vite dev",
  "installCommand": "pnpm install",
  "functions": {
    "api/index.mjs": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.mjs"
    }
  ],
  "regions": ["sin1"],
  "env": {
    "NODE_VERSION": "20"
  }
}
